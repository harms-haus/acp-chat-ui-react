{
  "name": "acp-react-chat-library",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test-core": "pnpm -F @harms-haus/acp-chat-core test",
    "test-core:coverage": "pnpm -F @harms-haus/acp-chat-core test:coverage",
    "test-react": "pnpm -F @harms-haus/acp-chat-react test",
    "test-react:coverage": "pnpm -F @harms-haus/acp-chat-react test:coverage",
    "test-bridge": "pnpm -F @harms-haus/acp-ws-bridge test",
    "test-bridge:coverage": "pnpm -F @harms-haus/acp-ws-bridge test:coverage",
    "test-bridge-all": "cd crates/acp-ws-bridge && cargo test && cd ../.. && pnpm test-bridge",
    "test:visual": "pnpm --filter @harms-haus/acp-harness-ui test:visual",
    "test:visual:update": "pnpm --filter @harms-haus/acp-harness-ui test:visual:update",
    "test:all": "pnpm test-core && pnpm test-react && cd crates/acp-ws-bridge && cargo test && cd ../.. && pnpm test-bridge",
    "lint": "eslint .",
    "check": "pnpm -r run check",
    "prepare": "husky",
    "perf:test": "node --experimental-strip-types scripts/perf-runner.ts",
    "bundle:check": "node --experimental-strip-types scripts/bundle-check.ts",
    "dev:harness": "pnpm --filter @harms-haus/acp-harness-ui dev",
    "dev:harness:host": "pnpm --filter @harms-haus/acp-harness-ui run dev:host",
    "dev:bridge": "cargo run --manifest-path crates/acp-ws-bridge/Cargo.toml --bin acp-bridge -- --addr 127.0.0.1:8765",
    "debug": "concurrently 'VITE_ENABLE_LIVE_MODE=true pnpm dev:harness' 'cargo run --manifest-path crates/acp-harness-server/Cargo.toml -- --live --addr 127.0.0.1:8765'",
    "debug:host": "concurrently 'VITE_ENABLE_LIVE_MODE=true pnpm dev:harness:host' 'cargo run --manifest-path crates/acp-harness-server/Cargo.toml -- --live --addr 0.0.0.0:8765'",
    "kill": "fuser -k 4173/tcp 8765/tcp 2>/dev/null || true",
    "test:coverage": "pnpm test-core:coverage && pnpm test-react:coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc-files --noEmit"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "^2.1.9",
    "canvas": "^3.2.3",
    "concurrently": "^9.2.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsc-files": "1.1.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.58.1",
    "vitest": "^2.1.0",
    "ws": "^8.20.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
