{
  "name": "acp-react-chat-library",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:visual": "pnpm --filter @acp/harness test:visual",
    "test:visual:update": "pnpm --filter @acp/harness test:visual:update",
    "check": "pnpm -r run check",
    "perf:test": "node --experimental-strip-types scripts/perf-runner.ts",
    "bundle:check": "node --experimental-strip-types scripts/bundle-check.ts",
    "dev:harness": "pnpm --filter @acp/harness dev",
    "dev:bridge": "cargo run --manifest-path crates/acp-bridge/Cargo.toml --bin acp-bridge -- --addr 127.0.0.1:8765",
    "debug": "concurrently 'VITE_ENABLE_LIVE_MODE=true pnpm dev:harness' 'cargo run --manifest-path crates/acp-bridge/Cargo.toml --bin acp-bridge -- --live --addr 127.0.0.1:8765'",
    "kill": "fuser -k 4173/tcp 8765/tcp 2>/dev/null || true"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "ws": "^8.20.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}